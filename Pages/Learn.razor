    {
        _driver = driver;
        _wait = new WebDriverWait(driver, TimeSpan.FromSeconds(10));
    }

    // -------------------- Locators --------------------
    private IWebElement UserField => _wait.Until(d => d.FindElement(By.Id(""user"")));
    private IWebElement PasswordField => _driver.FindElement(By.Id(""password""));
    private IWebElement LoginButton => _driver.FindElement(By.Id(""loginBtn""));

    // -------------------- Actions --------------------
    public void EnterUsername(string username) => UserField.SendKeys(username);
    public void EnterPassword(string password) => PasswordField.SendKeys(password);
    public void ClickLogin() => LoginButton.Click();

    // -------------------- Combined Method --------------------
    public void LoginAs(string username, string password)
    {
        EnterUsername(username);
        EnterPassword(password);
        ClickLogin();
    }
