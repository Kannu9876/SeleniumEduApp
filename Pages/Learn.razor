                    <div class="accordion-collapse collapse @(ActiveSection == "exp" ? "show" : "")">
                        <div class="list-group list-group-flush">
                            <button @onclick='() => LoadContent("C15")' class="list-group-item list-group-item-action small">15. Jenkins & Pipelines</button>
                            <button @onclick='() => LoadContent("C16")' class="list-group-item list-group-item-action small">16. Dockerization</button>
                            <button @onclick='() => LoadContent("C18")' class="list-group-item list-group-item-action small">18. Shadow DOM & JS</button>
