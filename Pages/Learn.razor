           case "C9":
    CurrentTitle = "Page Object Model (POM) - Professional QA Practices";

    CurrentBody = @"<p><b>Page Object Model (POM)</b> is the industry-standard design pattern for Selenium automation. It improves test maintenance, reduces code duplication, and separates page-specific locators and actions from test logic.</p>
                    <ul>
                        <li>Each web page or significant page component is represented as a separate C# class.</li>
                        <li>Locators are defined as properties or fields, and actions are methods encapsulating user interactions.</li>
                        <li>Helps make tests <b>readable, reusable, and maintainable</b>.</li>
                    </ul>
                    <p><b>Best Practices:</b></p>
                    <ul>
                        <li>Use <code>private IWebElement</code> properties for element locators.</li>
                        <li>Encapsulate all page interactions in methods.</li>
                        <li>Prefer constructor injection for the <code>IWebDriver</code> instance.</li>
                        <li>Include utility methods for repeated actions, e.g., waiting for elements.</li>
                    </ul>";

    CurrentCode = @"using OpenQA.Selenium;
using OpenQA.Selenium.Support.UI;

// -------------------- Login Page --------------------
public class LoginPage
{
