@code {
    private string ActiveSection = "beg"; 
    private string CurrentTitle = "";
    private string CurrentBody = "";
    private string CurrentCode = "";

    private void ToggleSection(string sectionName)
    {
        if (ActiveSection == sectionName) ActiveSection = ""; 
        else ActiveSection = sectionName; 
    }

    private void LoadContent(string id)
    {
        switch (id)
        {
            case "C1":
    CurrentTitle = "C# Fundamentals (For Automation Engineers)";

    CurrentBody = $@"<p>C# is not just a programming language in automation — it is the foundation for building scalable, maintainable, and enterprise-grade automation frameworks.</p>

    <p><b>1. Object-Oriented Programming (OOP)</b></p>
    <ul>
        <li><b>Encapsulation:</b> Keep locators private and expose only actions (best practice in Page Object Model).</li>
        <li><b>Inheritance:</b> BaseTest class is inherited by all test classes to reuse driver setup, teardown, and utilities.</li>
        <li><b>Polymorphism:</b> Helps in implementing flexible framework components (e.g., different browser setups).</li>
        <li><b>Abstraction:</b> Hide complex Selenium logic behind reusable methods.</li>
    </ul>

    <p><b>2. Collections & LINQ</b></p>
    <ul>
        <li>Use <code>List&lt;IWebElement&gt;</code> to handle multiple elements like search results, tables, etc.</li>
        <li>Use <code>Dictionary&lt;string, string&gt;</code> for configuration and test data.</li>
        <li><b>LINQ</b> is heavily used to filter elements dynamically.</li>
    </ul>

    <p><b>3. Exception Handling & Stability</b></p>
    <ul>
        <li>Handle Selenium exceptions like <b>NoSuchElementException</b>, <b>StaleElementReferenceException</b>.</li>
        <li>Always log errors properly instead of just printing.</li>
        <li>Use retry mechanisms for flaky elements.</li>
    </ul>

    <p><b>4. Delegates, Func & Lambda Expressions</b></p>
    <ul>
        <li>Used in <b>Explicit Waits</b> and custom wait conditions.</li>
        <li>Helps in writing cleaner and more dynamic code.</li>
    </ul>

    <p><b>5. File Handling & Serialization</b></p>
    <ul>
        <li>Read test data from JSON, Excel, or XML.</li>
        <li>Serialize/Deserialize objects for Data-Driven frameworks.</li>
    </ul>

    <p><b>6. Logging & Debugging</b></p>
    <ul>
        <li>Use logging frameworks (Log4Net / NLog) instead of Console.WriteLine.</li>
        <li>Capture screenshots on failure.</li>
    </ul>

    <p><b>Real-World Impact:</b></p>
    <ul>
        <li>Clean architecture</li>
        <li>Reusable framework</li>
        <li>Reduced maintenance cost</li>
        <li>Better debugging & reporting</li>
    </ul>

    <p><b>Pro Tip (Industry Standard):</b> Never write Selenium code directly in test methods. Always use layered architecture (Base → Page → Test).</p>";

    CurrentCode = @"// Base Test Class (Reusable Setup)
public class BaseTest
{
    protected IWebDriver driver;

    [SetUp]
    public void Setup()
    {
        driver = new ChromeDriver();
        driver.Manage().Window.Maximize();
    }

    [TearDown]
    public void TearDown()
    {
        if (driver != null)
        {
            driver.Quit();
        }
    }
}

// Example Utility with Exception Handling
public class ElementHelper
{
    private IWebDriver driver;

    public ElementHelper(IWebDriver driver)
    {
        this.driver = driver;
    }

    public IWebElement GetElement(By locator)
    {
        try
        {
            return driver.FindElement(locator);
        }
        catch (NoSuchElementException ex)
        {
            throw new Exception($""Element not found: {locator}"", ex);
        }
    }
}

// Example using LINQ with Elements
var elements = driver.FindElements(By.TagName(""a""));
var visibleLinks = elements.Where(e => e.Displayed).ToList();";
    break;

                case "C2":
    CurrentTitle = "Selenium WebDriver Fundamentals (Professional Level)";

    CurrentBody = $@"<p><b>Selenium WebDriver</b> is a browser automation tool that directly interacts with the browser using native APIs. It acts as a bridge between your test code and the browser.</p>

    <p><b>1. Architecture Understanding (Very Important)</b></p>
    <ul>
        <li>Your C# test code sends commands to WebDriver.</li>
        <li>WebDriver communicates with browser-specific drivers (ChromeDriver, GeckoDriver).</li>
        <li>The driver translates commands into browser actions.</li>
    </ul>

    <p><b>2. Key Components</b></p>
    <ul>
        <li><b>IWebDriver:</b> Controls browser lifecycle (launch, navigate, quit).</li>
        <li><b>IWebElement:</b> Represents elements on UI.</li>
        <li><b>By:</b> Locator strategy to find elements.</li>
        <li><b>Driver Executables:</b> ChromeDriver, EdgeDriver, etc.</li>
    </ul>

    <p><b>3. Browser Lifecycle Management</b></p>
    <ul>
        <li>Launch Browser</li>
        <li>Navigate to Application</li>
        <li>Perform Actions</li>
        <li>Validate Results</li>
        <li>Close / Quit Browser</li>
    </ul>

    <p><b>4. Best Practices (Industry Standard)</b></p>
    <ul>
        <li>Never initialize WebDriver inside test methods → use BaseTest class.</li>
        <li>Avoid hardcoding driver paths → use WebDriverManager.</li>
        <li>Always use <code>driver.Quit()</code> instead of Close().</li>
        <li>Do not use <code>Thread.Sleep()</code> → use waits.</li>
        <li>Run tests in headless mode in CI/CD pipelines.</li>
    </ul>

    <p><b>5. Browser Configuration</b></p>
    <ul>
        <li>Run tests in headless mode</li>
        <li>Disable notifications/popups</li>
        <li>Set custom browser capabilities</li>
    </ul>

    <p><b>6. Real-World Use Case</b></p>
    <ul>
        <li>Login automation</li>
        <li>Search functionality</li>
        <li>E-commerce checkout flow</li>
    </ul>

    <p><b>Pro Tip:</b> Always design WebDriver initialization in a reusable and configurable way (cross-browser support).</p>";

    CurrentCode = @"// Base Driver Setup (Reusable & Scalable)
public class DriverFactory
{
    public static IWebDriver GetDriver(string browser)
    {
        IWebDriver driver;

        switch (browser.ToLower())
        {
            case ""chrome"":
                var options = new ChromeOptions();
                options.AddArgument(""--start-maximized"");
                options.AddArgument(""--disable-notifications"");
                driver = new ChromeDriver(options);
                break;

            case ""headless"":
                var headlessOptions = new ChromeOptions();
                headlessOptions.AddArgument(""--headless"");
                driver = new ChromeDriver(headlessOptions);
                break;

            default:
                throw new Exception(""Browser not supported"");
        }

        return driver;
    }
}

// Usage in Test
IWebDriver driver = DriverFactory.GetDriver(""chrome"");
driver.Navigate().GoToUrl(""https://www.google.com"");

// Always quit driver
driver.Quit();";
    break;

            case "C3":
    CurrentTitle = "Basic Automation - Professional Level";

    CurrentBody = @"<p>Automating web interactions requires two key steps:</p>
                    <ol>
                        <li><b>Locate Elements:</b> Identify the element in the DOM using locators like <code>Id</code>, <code>Name</code>, <code>XPath</code>, and <code>CSS Selector</code>.</li>
                        <li><b>Perform Actions:</b> Execute commands on the element such as <code>Click()</code>, <code>SendKeys()</code>, and <code>Submit()</code>.</li>
                    </ol>

                    <p><b>Common Locator Strategies:</b></p>
                    <ul>
                        <li><b>Id:</b> Fastest and most reliable.</li>
                        <li><b>Name:</b> Useful for forms.</li>
                        <li><b>XPath:</b> Handles complex hierarchies and dynamic elements.</li>
                        <li><b>CSS Selector:</b> Lightweight alternative to XPath for styling-based paths.</li>
                    </ul>

                    <p><b>Action Commands:</b></p>
                    <ul>
                        <li><code>Click()</code> → Trigger buttons, links, or checkboxes.</li>
                        <li><code>SendKeys()</code> → Enter text into input fields.</li>
                        <li><code>Submit()</code> → Submit forms.</li>
                        <li><code>Clear()</code> → Clear existing text before sending new keys.</li>
                    </ul>

                    <p><b>Professional Best Practices:</b></p>
                    <ul>
                        <li>Wrap element interactions in reusable methods.</li>
                        <li>Use <code>WebDriverWait</code> for elements that may load dynamically.</li>
                        <li>Implement a BasePage class with common actions (Click, Type, Select).</li>
                        <li>Always validate element existence before performing actions to avoid <code>NoSuchElementException</code>.</li>
                    </ul>

                    <p><b>Example Use Cases:</b> Search automation, login forms, dropdown selection, and button clicks on any web application.</p>";

    CurrentCode = "using OpenQA.Selenium;\nusing OpenQA.Selenium.Support.UI;\n\n// Reusable BasePage class for element actions\npublic class BasePage\n{\n    protected IWebDriver driver;\n    protected WebDriverWait wait;\n\n    public BasePage(IWebDriver driver)\n    {\n        this.driver = driver;\n        wait = new WebDriverWait(driver, TimeSpan.FromSeconds(10));\n    }\n\n    public IWebElement FindElement(By locator)\n    {\n        return wait.Until(d => d.FindElement(locator));\n    }\n\n    public void Click(By locator)\n    {\n        FindElement(locator).Click();\n    }\n\n    public void Type(By locator, string text)\n    {\n        var element = FindElement(locator);\n        element.Clear();\n        element.SendKeys(text);\n    }\n}\n\n// Usage Example\nvar searchPage = new BasePage(driver);\nsearchPage.Type(By.Name(\"q\"), \"Selenium C# Tutorials\");\nsearchPage.Click(By.Name(\"btnK\"));";
    break;

           case "C4":
    CurrentTitle = "Synchronization (Waits) - Professional QA Practices";

    CurrentBody = @"<p>Web elements often load at different speeds due to network latency or dynamic page content. <b>Synchronization</b> ensures your scripts interact with elements only when they are ready, preventing <code>NoSuchElementException</code> or <code>ElementNotInteractableException</code>.</p>
                    <p><b>Types of Waits:</b></p>
                    <ul>
                        <li><b>Implicit Wait:</b> Applies globally for the lifetime of the WebDriver instance. Polls the DOM periodically until the element is found or timeout occurs.</li>
                        <li><b>Explicit Wait:</b> Waits for a specific condition for a particular element. Recommended for professional automation scripts.</li>
                        <li><b>Fluent Wait:</b> A more advanced form of explicit wait that allows custom polling intervals and ignores specific exceptions.</li>
                    </ul>
                    <p><b>Best Practices:</b></p>
                    <ul>
                        <li>Avoid mixing Implicit and Explicit waits together to prevent unpredictable wait times.</li>
                        <li>Always wait for conditions that matter (e.g., <code>ElementIsVisible</code>, <code>ElementToBeClickable</code>).</li>
                        <li>Encapsulate waits in reusable methods in your BasePage or Utility class.</li>
                        <li>Use Fluent Wait for highly dynamic content, such as AJAX-loaded elements.</li>
                    </ul>
                    <p>Synchronization is critical for building stable and reliable automation frameworks in professional QA environments.</p>";

    CurrentCode = @"using OpenQA.Selenium;
using OpenQA.Selenium.Support.UI;
using SeleniumExtras.WaitHelpers;

// -------------------- Implicit Wait --------------------
driver.Manage().Timeouts().ImplicitWait = TimeSpan.FromSeconds(5);

// -------------------- Explicit Wait --------------------
WebDriverWait wait = new WebDriverWait(driver, TimeSpan.FromSeconds(10));
IWebElement loginButton = wait.Until(ExpectedConditions.ElementToBeClickable(By.Id(""login-button"")));
loginButton.Click();

// -------------------- Fluent Wait --------------------
DefaultWait<IWebDriver> fluentWait = new DefaultWait<IWebDriver>(driver)
{
    Timeout = TimeSpan.FromSeconds(15),
    PollingInterval = TimeSpan.FromMilliseconds(500)
};
fluentWait.IgnoreExceptionTypes(typeof(NoSuchElementException));
IWebElement dynamicElement = fluentWait.Until(d => d.FindElement(By.CssSelector("".dynamic-element"")));
dynamicElement.Click();";
    break;

           case "C5":
    CurrentTitle = "Handling Web Elements - Professional QA Practices";

    CurrentBody = @"<p>Intermediate automation requires handling dynamic and non-standard web elements like <b>Dropdowns</b>, <b>JavaScript Alerts</b>, <b>Frames/iFrames</b>, and other interactive components. Proper handling ensures scripts remain stable across different scenarios.</p>
                    <ul>
                        <li><b>SelectElement:</b> A Selenium wrapper for <code>&lt;select&gt;</code> dropdowns. Provides <code>SelectByText</code>, <code>SelectByValue</code>, and <code>SelectByIndex</code>.</li>
                        <li><b>SwitchTo():</b> Changes the driver's context to an Alert, Frame, or Window.</li>
                        <li><b>Frames/iFrames:</b> Switch context using <code>driver.SwitchTo().Frame()</code> before interacting with elements inside.</li>
                        <li><b>Alerts:</b> Use <code>Accept()</code>, <code>Dismiss()</code>, <code>SendKeys()</code> for prompt boxes.</li>
                    </ul>
                    <p><b>Best Practices:</b></p>
                    <ul>
                        <li>Always switch back to the default content after interacting with Frames (<code>driver.SwitchTo().DefaultContent()</code>).</li>
                        <li>Wrap common element interactions in utility methods for reusability.</li>
                        <li>Use explicit waits for elements inside frames or alerts to avoid timing issues.</li>
                    </ul>";

    CurrentCode = @"using OpenQA.Selenium;
using OpenQA.Selenium.Support.UI;

// -------------------- Handling a Dropdown --------------------
var dropdownElement = driver.FindElement(By.Id(""dropdown-id""));
var select = new SelectElement(dropdownElement);
select.SelectByText(""Option 1""); // Can also use SelectByValue or SelectByIndex

// -------------------- Handling a JavaScript Alert --------------------
IAlert alert = driver.SwitchTo().Alert();
Console.WriteLine(alert.Text); // Optional: read the alert message
alert.Accept(); // or alert.Dismiss();

// -------------------- Handling Frames / iFrames --------------------
driver.SwitchTo().Frame(""frameNameOrId""); // Switch to frame
IWebElement frameButton = driver.FindElement(By.Id(""btnInsideFrame""));
frameButton.Click();
driver.SwitchTo().DefaultContent(); // Switch back to main document

// -------------------- Utility Example --------------------
public void SelectDropdownOption(By locator, string optionText)
{
    var selectElem = new SelectElement(driver.FindElement(locator));
    selectElem.SelectByText(optionText);
}";

    break;

           case "C6":
    CurrentTitle = "Advanced Locators - Professional QA Techniques";

    CurrentBody = @"<p>In real-world applications, many elements do not have stable IDs or names. Advanced locators like <b>XPath Axes</b> and <b>CSS Selectors with multiple attributes</b> allow precise targeting of elements.</p>
                    <ul>
                        <li><b>XPath Axes:</b> Navigate the DOM relative to another element (Parent, Child, Sibling).</li>
                        <li><b>CSS Attribute Selectors:</b> Target elements using multiple attributes for precision.</li>
                        <li><b>Best Practices:</b> Prefer <code>CSS Selectors</code> for performance; use XPath for complex hierarchies.</li>
                    </ul>
                    <p>Examples of professional use:</p>
                    <ul>
                        <li>Dynamic forms where IDs change per session.</li>
                        <li>Nested elements that require sibling or parent relationships.</li>
                        <li>Buttons with multiple states (enabled/disabled) identified via attributes.</li>
                    </ul>";

    CurrentCode = @"using OpenQA.Selenium;

// -------------------- XPath Example --------------------
// Locate an input field immediately following a label with text 'Email'
IWebElement emailInput = driver.FindElement(By.XPath(""//label[text()='Email']/following-sibling::input""));

// -------------------- CSS Selector Example --------------------
// Locate a submit button that has class 'btn' and is currently disabled
IWebElement submitBtn = driver.FindElement(By.CssSelector(""button.btn[type='submit'][disabled]""));

// -------------------- Recommended Usage --------------------
// Combine waits for stable automation
WebDriverWait wait = new WebDriverWait(driver, TimeSpan.FromSeconds(10));
IWebElement dynamicElement = wait.Until(d => d.FindElement(By.XPath(""//div[@class='container']//button[text()='Click Me']"")));";

    break;
    case "C7":
    CurrentTitle = "Fluent Wait Logic";

    CurrentBody = @"
        <p>As a QA engineer, I use <b>Fluent Wait</b> in Selenium to handle dynamic web elements that might not load immediately.</p>
        <p>Fluent Wait allows me to specify:</p>
        <ul>
            <li>A maximum wait time for an element or condition.</li>
            <li>How frequently to check the condition (polling interval).</li>
            <li>Exceptions to ignore while waiting (like NoSuchElementException).</li>
        </ul>
        <p>This helps make automated tests more reliable and reduces flaky failures due to timing issues.</p>
    ";

    CurrentCode = @"
var wait = new DefaultWait<IWebDriver>(driver)
{
    Timeout = TimeSpan.FromSeconds(30),
    PollingInterval = TimeSpan.FromSeconds(2)
};
wait.IgnoreExceptionTypes(typeof(NoSuchElementException));
var element = wait.Until(d => d.FindElement(By.Id(""dynamicElement"")));
    ";
    break;

