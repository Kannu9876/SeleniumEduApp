@page "/contact"

<div class="container mt-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">
            <h1>Contact Us</h1>
            <p class="lead">Have a question or feedback? We'd love to hear from you!</p>
            <hr />
            <div class="card shadow-sm border-0 bg-light p-5">
                <h4 class="mb-3">Get in Touch</h4>
                <p class="mb-1">For support or business inquiries, please email us at:</p>
                <a href="mailto:support@seleniumeduapp.com" class="h5 text-primary">support@seleniumeduapp.com</a>
                <p class="mt-4 text-muted">We aim to respond to all inquiries within 48 hours.</p>
            </div>
        </div>
    </div>
</div>