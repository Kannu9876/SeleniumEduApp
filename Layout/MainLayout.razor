@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        
        <div class="top-row px-4 d-flex justify-content-end align-items-center shadow-sm bg-white">
            <a href="about" class="text-decoration-none text-dark fw-bold mx-3">About Us</a>
            <a href="privacy" class="text-decoration-none text-dark fw-bold mx-3">Privacy</a>
            <a href="contact" class="text-decoration-none text-dark fw-bold mx-3">Contact</a>
        </div>
        <article class="content px-4 py-3">
