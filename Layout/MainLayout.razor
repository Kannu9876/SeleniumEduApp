        </article>
        <footer class="border-top footer text-muted mt-5 bg-light">
    <div class="container py-4">
        <div class="row">
            <div class="col-md-6 text-center text-md-start">
                &copy; 2026 - Selenium Master - <span class="text-dark font-weight-bold">seleniumeduapp.com</span>
            </div>
            <div class="col-md-6 text-center text-md-end">
                <a href="about" class="text-decoration-none mx-2 text-secondary">About</a>
                <a href="privacy" class="text-decoration-none mx-2 text-secondary">Privacy Policy</a>
                <a href="contact" class="text-decoration-none mx-2 text-secondary">Contact Us</a>
            </div>
        </div>
    </div>
</footer>

<style>
    /* Taaki footer page ke ekdum niche rahe */
    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    main {
        flex: 1;
    }
    footer {
        width: 100%;
    }
</style>
    </main>
</div>
