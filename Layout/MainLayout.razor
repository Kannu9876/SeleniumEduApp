@inherits LayoutComponentBase

<div class="page d-flex flex-column min-vh-100">

    @* --- TOP NAVIGATION BAR --- *@
    <nav class="navbar navbar-expand-md navbar-dark shadow-sm" style="background-color: rgb(5, 39, 103);">
        <div class="container-fluid px-4">
            
            <a class="navbar-brand fw-bold d-flex align-items-center" href="">
                <span class="fs-4">Selenium Master</span>
            </a>
            
            <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="@NavMenuCssClass navbar-collapse" @onclick="CollapseNavMenu">
                <ul class="navbar-nav ms-auto mb-2 mb-md-0 align-items-center">
                    
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="" Match="NavLinkMatch.All">Home</NavLink>
                    </li>
                    
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="learn">
                            <span class="bi bi-book-fill me-1" aria-hidden="true"></span> AI Tutor
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="debug">
                            <span class="bi bi-bug-fill me-1" aria-hidden="true"></span> Debug Bot
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="interview">
                            <span class="bi bi-person-lines-fill me-1" aria-hidden="true"></span> Interview Prep
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="projects">
                            <span class="bi bi-briefcase-fill me-1" aria-hidden="true"></span> Projects
                        </NavLink>
                    </li>

                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="about">About Us</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="privacy">Privacy</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white fw-bold mx-2" href="contact">Contact</NavLink>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    @* --- MAIN CONTENT --- *@
    <main class="flex-grow-1">
        <article class="content px-4 py-4">
            @Body
        </article>
    </main>

    @* --- FOOTER --- *@
    <footer class="border-top footer text-muted bg-light mt-auto">
        <div class="container-fluid py-3">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    &copy; 2026 - <b>seleniumeduapp.com</b>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="about" class="text-decoration-none mx-2">About</a>
                    <a href="privacy" class="text-decoration-none mx-2">Privacy Policy</a>
                    <a href="contact" class="text-decoration-none mx-2">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

</div>

@* --- HAMBURGER MENU KA C# CODE --- *@
@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CollapseNavMenu()
    {
        collapseNavMenu = true;
    }
}

<style>
    /* CSS for fixing layout */
    .sidebar { display: none !important; }
    .page { flex-direction: column !important; }
    main { display: flex; flex-direction: column; min-height: 100vh; }
    .content { flex: 1; }
    
    /* Hover effect for links */
    .nav-link:hover { color: #f8f9fa !important; text-decoration: underline; }
</style>