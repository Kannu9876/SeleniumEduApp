@inherits LayoutComponentBase

<div class="page d-flex flex-column min-vh-100">

    @* --- TOP NAVIGATION BAR --- *@
    <nav class="navbar navbar-expand-md navbar-dark shadow-sm" style="background-color: rgb(5, 39, 103);">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="">
                <span class="fs-4">Selenium Master</span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav ms-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link text-white fw-bold mx-2" href="about">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white fw-bold mx-2" href="privacy">Privacy</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white fw-bold mx-2" href="contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @* --- MAIN CONTENT --- *@
    <main class="flex-grow-1">
        <article class="content px-4 py-4">
            @Body
        </article>
    </main>

    @* --- FOOTER --- *@
    <footer class="border-top footer text-muted bg-light mt-auto">
        <div class="container-fluid py-3">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    &copy; 2026 - <b>seleniumeduapp.com</b>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="about" class="text-decoration-none mx-2">About</a>
                    <a href="privacy" class="text-decoration-none mx-2">Privacy Policy</a>
                    <a href="contact" class="text-decoration-none mx-2">Contact Us</a>
                </div>
            </div>
        </div>
    </footer>

</div>

<style>
    /* Ye CSS Blazor ke purane Sidebar design ko forcefully overwrite karega */
    .sidebar { display: none !important; }
    .page { flex-direction: column !important; }
    main { display: flex; flex-direction: column; min-height: 100vh; }
    .content { flex: 1; }
</style>